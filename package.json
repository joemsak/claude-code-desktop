{
  "name": "claude-code-desktop",
  "version": "2.1.4",
  "description": "Desktop app for managing multiple Claude Code terminal sessions",
  "main": "src/main/main.js",
  "scripts": {
    "start": "npm run rebuild && npm run bundle && electron .",
    "dev": "npm run bundle && electron .",
    "bundle": "node esbuild.config.js",
    "rebuild": "electron-rebuild -f -w node-pty",
    "dist": "npm run bundle && electron-builder",
    "install-app": "npm run dist && rm -rf '/Applications/Claude Code Desktop.app' && cp -R 'dist/mac-arm64/Claude Code Desktop.app' /Applications/ && echo 'Installed to /Applications/Claude Code Desktop.app'",
    "release:patch": "npm version patch && git push && git push --tags",
    "release:minor": "npm version minor && git push && git push --tags",
    "release:major": "npm version major && git push && git push --tags",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ test/",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joemsak/claude-code-desktop.git"
  },
  "author": "Joe Sak",
  "license": "MIT",
  "type": "commonjs",
  "build": {
    "appId": "com.claudecode.desktop",
    "productName": "Claude Code Desktop",
    "artifactName": "Claude-Code-Desktop-${arch}.${ext}",
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": [
        "dir",
        "pkg"
      ]
    },
    "files": [
      "src/main/**/*",
      "src/preload/**/*",
      "src/renderer/index.html",
      "src/renderer/styles.css",
      "src/renderer/bundle.js",
      "src/renderer/xterm.css",
      "node_modules/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ]
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "node-pty": "^1.1.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "husky": "^9.1.7",
    "vitest": "^4.1.0"
  }
}
